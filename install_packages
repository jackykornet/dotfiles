#!/bin/bash

# Detect all installed package managers
detect_package_managers() {
    local package_managers=("apt" "dnf" "yum" "zypper" "pacman")
    local found=()
    for manager in "${package_managers[@]}"; do
        if command -v "$manager" > /dev/null 2>&1; then
            found+=("$manager")
        fi
    done
    echo "${found[@]}"
}

# Install packages using the selected package manager
install_packages() {
    local manager=$1
    shift
    local packages=("$@")

    case "$manager" in
        apt)     sudo apt install -y "${packages[@]}" ;;
        dnf)     sudo dnf install -y "${packages[@]}" ;;
        yum)     sudo yum install -y "${packages[@]}" ;;
        zypper)  sudo zypper install -y "${packages[@]}" ;;
        pacman)  sudo pacman -S --noconfirm "${packages[@]}" ;;
        *)       echo "No supported package manager found."; exit 1 ;;
    esac
}

# --- Main ---
if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <package1> <package2> ..."
    exit 1
fi

read -ra FOUND_MANAGERS <<< "$(detect_package_managers)"

if [[ ${#FOUND_MANAGERS[@]} -eq 0 ]]; then
    echo "No supported package manager found. Exiting."
    exit 1

elif [[ ${#FOUND_MANAGERS[@]} -eq 1 ]]; then
    SELECTED_MANAGER="${FOUND_MANAGERS[0]}"
    echo "Detected package manager: $SELECTED_MANAGER"

else
    echo "Multiple package managers found. Please choose one:"
    for i in "${!FOUND_MANAGERS[@]}"; do
        echo "  $((i+1))) ${FOUND_MANAGERS[$i]}"
    done

    while true; do
        read -rp "Enter choice [1-${#FOUND_MANAGERS[@]}]: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#FOUND_MANAGERS[@]} )); then
            SELECTED_MANAGER="${FOUND_MANAGERS[$((choice-1))]}"
            break
        else
            echo "Invalid choice. Try again."
        fi
    done
fi

echo "Using: $SELECTED_MANAGER"
install_packages "$SELECTED_MANAGER" "$@"
